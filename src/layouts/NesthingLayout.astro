---
// src/layouts/NesthingLayout.astro
import PageLayout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import Footer from '~/components/widgets/Footer.astro'; // ✨ 新增：引入 Footer 组件

// 📦 新增：只从 navigation 导入你之前写好的中英文两条页脚数据
import { footerData, footerDataZh } from '~/navigation';

const { metadata } = Astro.props;

// 🧠 核心黑魔法 1：自动感知当前用户是在中文路径还是英文路径
const currentUrl = Astro.url.pathname;
const isZh = currentUrl.includes('/aio/zh');

// 🎯 彻底锁死：如果是中文页就回 /aio/zh，英文页就回 /aio
const homeUrl = isZh ? '/aio/zh' : '/aio';

// ✨ 新增：让底部的 Footer 也完美吃进中英文分流
const currentFooterData = isZh ? footerDataZh : footerData;

// 动态分流中英文菜单
const links = isZh
  ? [
      { text: '核心服务', href: '/aio/zh/services' },
      { text: '客户案例', href: '/aio/zh/cases' },
      { text: '技术博客', href: '/blog' },
      { text: 'English', href: '/aio' },
    ]
  : [
      { text: 'Our Service', href: '/aio/services' },
      { text: 'Case Study', href: '/aio/cases' },
      { text: 'Blog', href: '/blog' },
      { text: '中文', href: '/aio/zh' },
    ];

const actions = isZh 
  ? [{ text: '立即部署', href: '/aio/zh/contact', variant: 'primary' }]
  : [{ text: 'Deploy Now', href: '/aio/contact', variant: 'primary' }];

// 🧠 核心黑魔法 2：让 WhatsApp 气泡文案动态适配中英文
const whatsappTooltip = isZh ? '在线接入技术工程师' : 'WhatsApp An Engineer';
const whatsappText = isZh ? '我需要一份免费的%20AI%20可见性审计报告。' : 'I%20need%20a%20complimentary%20AI%20Visibility%20Audit%20Report.';
---

<PageLayout metadata={metadata}>
  <!-- ✨ 这里通过 homeUrl={homeUrl} 属性，强制修正了 Logo 的点击跳转行为 -->
  <Header slot="header" homeUrl={homeUrl} links={links} actions={actions} isSticky />
  
  <!-- 承接各个子页面的主体内容 -->
  <slot />

  <!-- ✨ 新增：在这里优雅地把 Footer 吐出来，并解构其中英文配置，彻底干掉 Company 英文残留 -->
  <Footer slot="footer" {...currentFooterData} />

  <!-- 🎯 全局置底 WhatsApp 浮动按钮 -->
  <a 
    href={`https://wa.me/+60128631019?text=${whatsappText}`}
    target="_blank" 
    rel="noopener noreferrer"
    class="fixed bottom-6 right-6 z-50 flex items-center justify-center w-14 h-14 bg-[#25D366] text-white rounded-full shadow-[0_4px_20px_rgba(37,211,102,0.4)] hover:bg-[#20ba5a] transition-all duration-300 hover:scale-110 active:scale-95 group"
    aria-label="Contact on WhatsApp"
  >
    <!-- WhatsApp SVG 图标 -->
    <svg class="w-7 h-7 fill-current" viewBox="0 0 24 24">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.746.953 3.71 1.454 5.709 1.455h.008c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
    </svg>
    <!-- 动态提示气泡 -->
    <span class="absolute right-16 scale-0 group-hover:scale-100 transition-all bg-[var(--color-linear-card)] border border-[var(--color-linear-border)] text-[var(--color-text-primary)] text-xs font-mono px-3 py-1.5 rounded-lg whitespace-nowrap shadow-xl">
      {whatsappTooltip}
    </span>
  </a>
</PageLayout>