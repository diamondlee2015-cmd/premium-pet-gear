---
// src/layouts/NesthingLayout.astro
import PageLayout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import Footer from '~/components/widgets/Footer.astro'; 

// 📦 安全引入：尝试导入中英文页脚数据。
// 如果在新项目里还没有配好 footerDataZh，下面会做自动容错降级，确保 Vercel 绝对不报错！
import * as navigationData from '~/navigation';

const { metadata } = Astro.props;

// 🧠 核心逻辑 1：自动感知当前用户是在中文路径还是英文路径
const currentUrl = Astro.url.pathname;
const isZh = currentUrl.includes('/zh/') || currentUrl.endsWith('/zh');

// 🎯 锁死新大首页。中文页回 /zh，英文页直接回根目录 /
const homeUrl = isZh ? '/zh' : '/';

// 🛡️ 容错降级保护：如果 navigation 里没有导出 footerDataZh，则安全降级使用基础的 footerData
const defaultFooter = navigationData.footerData || {};
const defaultFooterZh = navigationData.footerDataZh || navigationData.footerData || {};
const currentFooterData = isZh ? defaultFooterZh : defaultFooter;

// 🎯 动态分流中英文菜单，全面砍掉 /aio 尾巴
const links = isZh
  ? [
      { text: '核心服务', href: '/zh/services' },
      { text: '客户案例', href: '/zh/cases' },
      { text: '技术博客', href: '/blog' }, 
      { text: 'English', href: '/' },       
    ]
  : [
      { text: 'Our Service', href: '/services' },
      { text: 'Case Study', href: '/cases' },
      { text: 'Blog', href: '/blog' },
      { text: '中文', href: '/zh' },          
    ];

// 🎯 按钮行动点同样砍掉 /aio
const actions = isZh 
  ? [{ text: '立即部署', href: '/zh/contact', variant: 'primary' }]
  : [{ text: 'Deploy Now', href: '/contact', variant: 'primary' }];

// 🧠 核心逻辑 2：让 WhatsApp 气泡文案动态适配中英文
const whatsappTooltip = isZh ? '在线接入技术工程师' : 'WhatsApp An Engineer';
const whatsappText = isZh ? '我需要一份免费的%20AI%20可见性审计报告。' : 'I%20need%20a%20complimentary%20AI%20Visibility%20Audit%20Report.';
---

<PageLayout metadata={metadata}>
  <Header slot="header" homeUrl={homeUrl} links={links} actions={actions} isSticky />
  
  <slot />

  <Footer slot="footer" {...currentFooterData} />

  <div style="position: relative; z-index: 999999 !important;">
    
    <button
      id="go-to-top"
      class="fixed bottom-24 right-6 md:bottom-28 md:right-8 flex items-center justify-center w-12 h-12 bg-[#1f2438] hover:bg-[#2f3756] text-white rounded-full border border-[#303654] shadow-2xl transition-all duration-300 translate-y-10 opacity-0 pointer-events-none scale-90 hover:scale-110 group cursor-pointer"
      aria-label="Go to Top"
    >
      <svg class="w-5 h-5 transition-transform group-hover:-translate-y-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5"></path>
      </svg>
    </button>

    <a 
      href={`https://wa.me/+60128631019?text=${whatsappText}`}
      target="_blank" 
      rel="noopener noreferrer"
      style="display: flex !important; visibility: visible !important; opacity: 1 !important;"
      class="fixed bottom-6 right-6 md:bottom-8 md:right-8 items-center justify-center w-14 h-14 bg-[#25D366] text-white rounded-full shadow-[0_4px_20px_rgba(37,211,102,0.4)] hover:bg-[#20ba5a] transition-all duration-300 hover:scale-110 active:scale-95 group"
      aria-label="Contact on WhatsApp"
    >
      <svg class="w-7 h-7 fill-current" viewBox="0 0 24 24">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.746.953 3.71 1.454 5.709 1.455h.008c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
      </svg>
      <span class="absolute right-16 scale-0 md:group-hover:scale-100 transition-all bg-[#0b0d19] border border-[#1f2438] text-white text-xs font-mono px-3 py-1.5 rounded-lg whitespace-nowrap shadow-xl">
        {whatsappTooltip}
      </span>
    </a>

  </div>

  <script>
    // 建立初始化函数，兼容 Astro 的多页面局部感知
    function initScrollEffects() {
      const topBtn = document.getElementById('go-to-top');
      if (!topBtn) return;

      // 实时计算滚动条高度
      window.addEventListener('scroll', () => {
        if (window.scrollY > 400) {
          // 超过 400 像素，平滑进入并完全显现
          topBtn.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-10', 'scale-90');
          topBtn.classList.add('opacity-100', 'translate-y-0', 'scale-100');
        } else {
          // 滚回顶部，自动隐藏并向下缩回
          topBtn.classList.add('opacity-0', 'pointer-events-none', 'translate-y-10', 'scale-90');
          topBtn.classList.remove('opacity-100', 'translate-y-0', 'scale-100');
        }
      });

      // 绑定点击事件：丝滑滚回最顶端
      topBtn.addEventListener('click', () => {
        window.scrollTo({
          top: 0,
          behavior: 'smooth'
        });
      });
    }

    // 初始化运行
    initScrollEffects();
    // 兼容 Astro 页面切换（View Transitions）时脚本不会失效
    document.addEventListener('astro:after-swap', initScrollEffects);
  </script>
</PageLayout>