---
import { getCollection } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';

// 获取所有产品并截取最新的 8 个作为新品展示
const allProducts = await getCollection('products');
const newArrivals = allProducts.slice(0, 8);
---

<Layout metadata={{ title: 'New Arrivals | Premium Wholesale Catalog' }}>
  <section class="py-16 bg-slate-50 dark:bg-slate-900/20 min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      
      <div class="border-b border-gray-200 dark:border-slate-800 pb-8 mb-12">
        <span class="text-xs font-bold text-rose-600 dark:text-rose-400 uppercase tracking-widest">Quarterly Launch</span>
        <h1 class="text-4xl font-extrabold text-gray-900 dark:text-white mt-2 tracking-tight">New Arrivals Directory</h1>
        <p class="text-muted text-lg mt-2">Explore our freshly updated factory-direct inventory lines available for immediate order commitment.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        {newArrivals.map(prod => (
          <a href={`/products/${prod.slug}`} class="group bg-white dark:bg-slate-900 p-5 rounded-xl border border-gray-100 dark:border-slate-800 shadow-sm hover:shadow-md transition-all duration-200 flex flex-col justify-between">
            <div class="bg-slate-50 dark:bg-slate-800/50 rounded-lg overflow-hidden h-48 flex items-center justify-center mb-4">
              <img src={prod.data.image} alt={prod.data.title} class="max-h-full max-w-full object-contain group-hover:scale-105 transition-transform duration-200" />
            </div>
            <div>
              <span class="text-[10px] font-bold text-rose-600 uppercase tracking-wider block mb-1">New</span>
              <h3 class="font-bold text-gray-900 dark:text-white text-sm line-clamp-2 group-hover:text-primary transition-colors">{prod.data.title}</h3>
              <div class="flex items-center justify-between mt-3 pt-3 border-t border-gray-50 dark:border-slate-800/60 text-xs text-muted">
                <span class="font-mono">MOQ: {prod.data.moq || '1 Carton'}</span>
                <span class="font-medium text-primary group-hover:underline">View Specs →</span>
              </div>
            </div>
          </a>
        ))}
      </div>
      
    </div>
  </section>
</Layout>