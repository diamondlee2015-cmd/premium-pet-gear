---
import { getCollection } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro'; // 🌟 确保补齐了 Layout 导入

export async function getStaticPaths() {
  const allProducts = await getCollection('products');
  return allProducts.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { title, sku, category, image, moq } = entry.data;

// 🌟 [修复 Bug 1]：必须渲染并导出 Content 组件，Markdown 正文才能生效
const { Content } = await entry.render();

// 🌟 [修复 Bug 2]：动态获取同类目下的相关产品（排除当前产品，最多取3个）
const allProducts = await getCollection('products');
const relatedProducts = allProducts
  .filter((prod) => prod.data.category === category && prod.slug !== entry.slug)
  .slice(0, 3);
---

<Layout metadata={{ title: `${title} | B2B Wholesale Directory` }}>
  <section class="py-16 bg-slate-50 dark:bg-slate-900/20 min-h-screen">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      
      <nav class="text-xs text-muted mb-6 uppercase tracking-wider">
        <a href="/" class="hover:underline">Home</a> / 
        <a href={`/categories/${category}`} class="hover:underline">{category.replace(/-/g, ' ')}</a> / 
        <span class="text-gray-400">{sku || 'Product Detail'}</span>
      </nav>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 bg-white dark:bg-slate-900 p-8 rounded-2xl border border-gray-100 dark:border-slate-800 shadow-sm">
        
        <div class="flex items-center justify-center bg-slate-50 dark:bg-slate-800/50 rounded-xl overflow-hidden min-h-[400px]">
          <img src={image} alt={title} class="w-full h-auto object-contain max-h-[500px]" />
        </div>

        <div class="flex flex-col justify-between relative">
          <div>
            <span class="text-xs font-bold text-primary dark:text-accent uppercase tracking-widest">{category.replace(/-/g, ' ')}</span>
            <h1 class="text-3xl font-extrabold text-gray-900 dark:text-white mt-2 mb-4 tracking-tight">{title}</h1>
            <p class="text-sm text-muted font-mono mb-6">SKU: {sku || 'N/A'}</p>
            
            <hr class="border-gray-100 dark:border-slate-800 my-4" />

            <div class="prose prose-sm dark:prose-invert text-gray-600 dark:text-slate-400">
              <Content />
            </div>
          </div>

          <div class="mt-8 relative p-6 rounded-xl border border-dashed border-gray-200 dark:border-slate-700 bg-slate-50/50 dark:bg-slate-900/50 min-h-[160px]">
            <div id="auth-gate-wall" class="absolute inset-0 bg-white/95 dark:bg-slate-900/95 backdrop-blur-sm z-50 flex flex-col items-center justify-center text-center p-6 rounded-xl hidden">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-primary dark:text-accent mb-3" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path d="M5 13a2 2 0 0 1 2 -2h10a2 2 0 0 1 2 2v6a2 2 0 0 1 -2 2h-10a2 2 0 0 1 -2 -2v-6z" /><path d="M11 16a1 1 0 1 0 2 0a1 1 0 0 0 -2 0" /><path d="M8 11v-4a4 4 0 1 1 8 0v4" /></svg>
              <h4 class="text-base font-bold text-gray-900 dark:text-white">Wholesale Specifications Locked</h4>
              <p class="text-xs text-muted max-w-xs mt-1 mb-4">Pricing tiers are visible to verified buyers only.</p>
              <div class="flex items-center space-x-3">
                <a href="/signup" class="text-xs font-semibold bg-primary text-white px-4 py-2 rounded-md">Register</a>
                <a href="/login" class="text-xs font-semibold text-gray-600 dark:text-slate-400 hover:underline">Log In</a>
              </div>
            </div>

            <div class="space-y-3 text-sm">
              <div class="flex justify-between"><span class="text-muted">Standard MOQ:</span> <span class="font-semibold text-gray-900 dark:text-white">{moq}</span></div>
              <div class="flex justify-between"><span class="text-muted">Wholesale Price:</span> <span class="font-bold text-emerald-600 dark:text-emerald-400 font-mono">FOB Verified Inquiry</span></div>
              <div class="flex justify-between"><span class="text-muted">Biosecurity Fumigation:</span> <span class="text-gray-900 dark:text-white font-medium">Yes (SGS Export Standard)</span></div>
            </div>
          </div>

        </div>
      </div>

      {relatedProducts.length > 0 && (
        <div class="mt-20">
          <div class="flex items-center justify-between border-b border-gray-100 dark:border-slate-800 pb-4 mb-8">
            <h3 class="text-xl font-extrabold text-gray-900 dark:text-white tracking-tight">Related Products from this Line</h3>
          </div>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
            {relatedProducts.map(prod => (
              <a href={`/products/${prod.slug}`} class="group bg-white dark:bg-slate-900 p-5 rounded-xl border border-gray-100 dark:border-slate-800 shadow-sm hover:shadow-md transition-all duration-200 flex flex-col justify-between">
                <div class="bg-slate-50 dark:bg-slate-800/50 rounded-lg overflow-hidden h-48 flex items-center justify-center mb-4">
                  <img src={prod.data.image} alt={prod.data.title} class="max-h-full max-w-full object-contain" />
                </div>
                <div>
                  <h4 class="font-bold text-gray-900 dark:text-white text-sm line-clamp-2">{prod.data.title}</h4>
                  <div class="flex items-center justify-between mt-3 pt-3 border-t border-gray-50 dark:border-slate-800/60 text-xs text-muted">
                    <span class="font-mono">SKU: {prod.data.sku || 'N/A'}</span>
                    <span class="font-medium text-primary">View →</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

    </div>
  </section>
</Layout>

<script>
  function enforceB2BGate() {
    const isUserLoggedIn = localStorage.getItem('b2b_user_token');
    const gateWall = document.getElementById('auth-gate-wall');
    if (!isUserLoggedIn && gateWall) {
      gateWall.classList.remove('hidden');
    }
  }
  document.addEventListener('DOMContentLoaded', enforceB2BGate);
  document.addEventListener('astro:after-swap', enforceB2BGate);
</script>