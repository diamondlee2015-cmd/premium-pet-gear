---
// src/pages/zh/blog.astro

// 1. 引入“读取原料”的工具函数（它会自动去 src/data/post 目录下抓取所有的 .md 文件）
import { fetchPosts } from '~/utils/blog'; 

// 2. 引入“排版衣服”（组件）
import BlogList from '~/components/blog/List.astro'; 
import NesthingLayout from '~/layouts/NesthingLayout.astro';

// 3. 执行读取：此时 posts 变量里就包含了你在 src/data/post 里的猫砂报告数据
const posts = await fetchPosts(); 
---

<NesthingLayout metadata={{ title: 'blog' }}>
  <BlogList posts={posts} />
</NesthingLayout>