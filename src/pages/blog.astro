---
// src/pages/blog.astro

// 1. 引入“读取原料”的工具函数
import { fetchPosts } from '~/utils/blog'; 

// 2. 引入布局和排版组件
import BlogList from '~/components/blog/List.astro'; 
import NesthingLayout from '~/layouts/NesthingLayout.astro'; // 如果英文版也用 NesthingLayout 就保持这样

// 3. 先把所有的原始文章抓出来，命名为 allPosts
const allPosts = await fetchPosts(); 

// 4. 过滤：排除掉所有以 'zh/' 开头的文章（!代表取反），剩下的就是英文文章
const posts = allPosts.filter(post => !post.slug.startsWith('zh/'));
---

<NesthingLayout metadata={{ title: 'Blog' }}>
  <BlogList posts={posts} />
</NesthingLayout>