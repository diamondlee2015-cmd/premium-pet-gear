---
import Layout from '~/layouts/NesthingLayout.astro';
import ResilienceCTA from '~/components/ResilienceCTA.astro';
---
<Layout metadata={{ title: 'Intercept Your Leakage | Contact Nesthing' }}>
  <div class="max-w-3xl mx-auto px-6 py-24 text-center">
    <h1 class="text-4xl font-extrabold text-white mb-6">Deploy Your Engine Within 48 Hours</h1>
    <p class="text-gray-400 mb-12">Stop losing law retainers and high-ticket aesthetic patients to your competitors' AI pipelines.</p>
    
    <div class="border border-[var(--color-linear-border)] bg-[var(--color-linear-card)]/50 rounded-2xl p-8 max-w-xl mx-auto">
      <div class="text-sm text-gray-500 uppercase tracking-widest mb-2">Direct Secure Intake</div>
      <!-- 隐藏你的后端雅虎邮箱，只暴露Cloudflare路由后的前台邮箱 -->
      <a href="mailto:help@nesthing.com" class="text-2xl font-bold text-cyan-400 hover:underline">
        help@nesthing.com
      </a>
      <p class="text-xs text-gray-500 mt-4">Encrypted routed via Cloudflare Secure Gateway.</p>
    </div>
  </div>
</Layout>