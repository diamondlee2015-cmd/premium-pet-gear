---
// src/pages/zh/index.astro
// 📦 1. 扔掉重复的 Layout 定义，直接引入我们加固过的全局核心布局
import NesthingLayout from '~/layouts/NesthingLayout.astro';

// 🚀 2. 引入你中文首页内容真正需要的一一对应的组件
// （请根据你英文首页实际上用了哪些组件，在这里精准引入中文版组件，比如 Hero、Features、Content 等）
import Hero from '~/components/widgets/Hero.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';

const metadata = {
  title: 'Nesthing | Agentic Workflow & GEO Architecture',
  ignoreTitleTemplate: true,
};
---

<NesthingLayout metadata={metadata}>
  
  <Hero
    actions={[
      { variant: 'primary', text: 'Deploy Now', href: '/zh/contact' },
      { text: 'Learn More', href: '#features' },
    ]}
    image={{ src: '~/assets/images/hero-image.png', alt: 'Nesthing Hero Image' }}
  >
    <fragment slot="title">
      当高净值客户在 ChatGPT 搜索最佳服务时...
    </fragment>

    <fragment slot="subtitle">
      我们部署自主运行的业务 Agent，拦截流量流失，自动化用户行为，并提升品牌在各大生成式 AI 引擎（GEO）中的推荐权重。
    </fragment>
  </Hero>

  </NesthingLayout>