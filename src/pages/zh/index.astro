---
// src/pages/zh/index.astro
// 📦 使用刚刚魔改加固、自带超高层级悬浮按钮和返回顶部引擎的专属布局
import Layout from '~/layouts/NesthingLayout.astro';
import ResilienceCTA from '~/components/ResilienceCTA.astro';

const metadata = {
  title: 'AI 品牌估值护盾与 GEO 流量拦截架构 | Nesthing',
};
---
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "为什么 ChatGPT 优先推荐我的竞争对手，而不是我的事务所或诊所？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "大语言模型（LLM）严重依赖向量数据库集群节点。如果您的企业缺乏结构化的 JSON-LD 实体图谱架构以及高权重的 RAG 锚点引用，AI 搜索引擎就会自动绕过您的品牌。我们的 Engine Beta 正是注入这种底层架构，强制 AI 进行精准引用和推荐。"
      }
    },
    {
      "@type": "Question",
      "name": "Engine Alpha 是如何提升我的 WhatsApp 获客线索转化率率的？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "传统的表单或消息咨询往往需要等待数小时的人工响应。Engine Alpha 采用全自主运行的 n8n 工作流，24/7 全天候实时拦截线索，自动进行意向初筛、为患者或客户打上标签，并在 60 秒内将完整精准的上下文背景直接推送到您的 WhatsApp 上。"
      }
    },
    {
      "@type": "Question",
      "name": "这套架构能对抗行业恶意负面舆论或 AI 幻觉吗？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "完全可以。当权威数据 Schema 字段留白时，LLM 往往会泛化或误读风险。通过部署我们的 Agentic 自动化工作流，我们能够持续监控各大 LLM 的 API 集群，并在 72 小时内迅速对高权重索引中的语义信息异常进行精准修补与校正。"
      }
    }
  ]
}
</script>

<Layout metadata={metadata}>
  <style is:global>
    :root {
      --color-linear-bg: #000212;
      --color-linear-card: #0b0d19;
      --color-linear-border: #1f2438;
      --color-linear-purple: #5e6ad2;
      --color-linear-green: #10b981;
      --color-text-primary: #f7f8f8;
      --color-text-muted: #b4bcd0;
    }
    
    /* 模拟 Linear 标志性的背景微弱环境光晕 */
    .linear-glow {
      position: relative;
    }
    .linear-glow::before {
      content: "";
      position: absolute;
      top: -20%;
      left: 50%;
      transform: translateX(-50%);
      width: 600px;
      height: 300px;
      background: radial-gradient(circle, rgba(94,106,210,0.15) 0%, rgba(0,2,18,0) 70%);
      border-radius: 50%;
      z-index: 0;
      pointer-events: none;
    }
  </style>

  <div class="bg-[var(--color-linear-bg)] text-[var(--color-text-primary)] min-h-screen antialiased select-none font-sans relative pb-24">
    
    <div class="max-w-6xl mx-auto flex justify-end items-center px-6 pt-6">
      <div class="flex items-center gap-6 text-sm font-medium text-[var(--color-text-muted)]">
        <a href="/blog" class="hover:text-white transition">技术博客</a>
        <a href="/zh/contact" class="hover:text-white transition">联系我们</a>
        
        <div class="flex items-center gap-1.5 bg-white/5 border border-[var(--color-linear-border)] rounded-full px-2.5 py-1 text-xs">
          <a href="/" class="hover:text-white transition px-1.5 py-0.5">EN</a>
          <span class="text-gray-600">/</span>
          <span class="text-white font-bold px-1.5 py-0.5 rounded-full bg-[var(--color-linear-purple)]/30">中文</span>
        </div>
      </div>
    </div>

    <div class="max-w-6xl mx-auto px-6 pt-16 pb-16 text-center linear-glow">
      <span class="relative z-10 inline-block text-[11px] font-semibold tracking-widest text-[var(--color-linear-purple)] uppercase bg-[var(--color-linear-purple)]/10 px-3 py-1 rounded-full border border-[var(--color-linear-purple)]/20">
        Agentic 工作流 & GEO 架构级解决方案
      </span>
      
      <h1 class="relative z-10 text-3xl md:text-5xl font-extrabold tracking-tight text-white mt-6 mb-8 max-w-4xl mx-auto leading-[1.25]">
        当高净值患者在 ChatGPT 寻找最佳医美诊所，或客户搜索顶尖律所时，<br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-[var(--color-linear-purple)] to-[var(--color-linear-green)]">
          AI 正在疯狂推荐您的竞争对手。
        </span>
      </h1>
      
      <p class="relative z-10 text-base md:text-lg text-[var(--color-text-muted)] max-w-3xl mx-auto mb-12 leading-relaxed font-light">
        别再让算法盲区悄悄偷走您的高客单价客户。我们部署自主运行的数字化决策引擎，精准拦截流量流失，实现全自动跟进，迫使主流 AI 生成式搜索引擎优先推荐您的品牌。
      </p>

      <div class="relative max-w-5xl mx-auto my-16 rounded-2xl border border-[var(--color-linear-border)] bg-[var(--color-linear-card)]/40 p-2 shadow-[0_0_50px_rgba(0,0,0,0.8),_inset_0_1px_20px_rgba(255,255,255,0.05)] backdrop-blur-sm group overflow-hidden">
        <div class="w-full aspect-[16/10] md:aspect-[16/9] bg-gradient-to-b from-slate-900 to-[#000212] rounded-xl overflow-hidden relative">
          <img 
            src="/images/hero-flow.webp" 
            alt="AIO 护盾 Agentic 工作流架构仪表盘" 
            class="w-full h-full object-cover object-top opacity-90 group-hover:opacity-100 transition-opacity duration-500"
            loading="eager"
            decoding="async"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-linear-bg)] via-transparent to-transparent opacity-90 pointer-events-none"></div>
        </div>
      </div>
    </div>

    <div class="max-w-5xl mx-auto px-6 py-20 border-t border-[var(--color-linear-border)]">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-12 tracking-tight text-white">
        核心痛点：算法层面的客户截流与高昂的运营摩擦
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="border border-[var(--color-linear-border)] bg-[var(--color-linear-card)]/40 rounded-2xl p-8 hover:bg-[var(--color-linear-card)]/60 transition-colors duration-300">
          <h3 class="text-xl font-bold text-white mb-3">流量黑洞效应</h3>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
            传统 SEO 只能带来点击，而 ChatGPT 和 Google AI Overviews（生成式搜索）在用户点击网页<strong class="text-white">之前</strong>就已经完成了内容拦截。如果您未曾出现在 AI 的原生回答与引用中，那么在线上您的品牌将不复存在。
          </p>
        </div>
        <div class="border border-[var(--color-linear-border)] bg-[var(--color-linear-card)]/40 rounded-2xl p-8 hover:bg-[var(--color-linear-card)]/60 transition-colors duration-300">
          <h3 class="text-xl font-bold text-white mb-3">转化链条脱节</h3>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
            高价值意向客户往往在深夜 11 点咨询服务。传统的人工客服响应滞后通常长达 12 小时。等到第二天清晨，这批客户早已流失并完成了竞争对手的预约。
          </p>
        </div>
      </div>
    </div>

    <div class="max-w-5xl mx-auto px-6 pb-20">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-12 tracking-tight text-white">
        核心解法：双引擎数字化交付框架
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="border border-[var(--color-linear-border)] bg-gradient-to-b from-[var(--color-linear-card)]/80 to-transparent rounded-2xl p-8 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-emerald-400 to-cyan-500"></div>
          <div class="text-xs font-mono text-cyan-400 mb-3 tracking-widest uppercase">Engine Alpha</div>
          <h3 class="text-2xl font-bold text-white mb-4">24/7 自主运行线索接入管道</h3>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
            在 60 秒内即时对高意向客户线索进行初筛、画像打标、并精准分流至您的 CRM 或 WhatsApp 销售端——全程自动，无需增加一房人工成本。
          </p>
        </div>
        <div class="border border-[var(--color-linear-border)] bg-gradient-to-b from-[var(--color-linear-card)]/80 to-transparent rounded-2xl p-8 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-purple-500 to-pink-500"></div>
          <div class="text-xs font-mono text-purple-400 mb-3 tracking-widest uppercase">Engine Beta</div>
          <h3 class="text-2xl font-bold text-white mb-4">LLM 推荐引擎与知识引用护盾</h3>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
            将高权重的语义实体数据注入全局知识图谱，确保您的品牌在 SearchGPT、Perplexity 及 Gemini 等生成式 AI 搜索中，稳居核心推荐位与文献引用序列。
          </p>
        </div>
      </div>
    </div>

    <div class="max-w-4xl mx-auto px-6 py-16 border-t border-[var(--color-linear-border)]">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-12 tracking-tight text-white">引擎技术规范与常见解答 (FAQs)</h2>
      <div class="space-y-4">
        <div class="border border-[var(--color-linear-border)] bg-[var(--color-linear-card)]/30 rounded-xl p-6">
          <h3 class="text-base font-bold text-white mb-2">Q: 为什么 ChatGPT 优先推荐我的竞争对手，而不是我的事务所或诊所？</h3>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">A: 大语言模型（LLM）严重依赖向量数据库集群节点。如果您的企业缺乏结构化的 JSON-LD 实体图谱架构以及高权重的 RAG 锚点引用，AI 搜索引擎就会自动绕过您的品牌。我们的 Engine Beta 正是注入这种底层架构，强制 AI 进行精准引用和推荐。</p>
        </div>
        <div class="border border-[var(--color-linear-border)] bg-[var(--color-linear-card)]/30 rounded-xl p-6">
          <h3 class="text-base font-bold text-white mb-2">Q: Engine Alpha 是如何提升我的 WhatsApp 获客线索转化率的？</h3>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">A: 传统的表单或消息咨询往往需要等待数小时的人工响应。Engine Alpha 采用全自主运行的 n8n 工作流，24/7 全天候实时拦截线索，自动进行意向初筛、为患者或客户打上标签，并在 60 秒内将完整精准的上下文背景直接推送到您的 WhatsApp 上。</p>
        </div>
        <div class="border border-[var(--color-linear-border)] bg-[var(--color-linear-card)]/30 rounded-xl p-6">
          <h3 class="text-base font-bold text-white mb-2">Q: 这套架构能对抗行业恶意负面舆论或 AI 幻觉吗？</h3>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">A: 完全可以。当权威数据 Schema 字段留白时，LLM 往往会泛化或误读风险。通过部署我们的 Agentic 自动化工作流，我们能够持续监控各大 LLM 的 API 集群，并在 72 小时内迅速对高权重索引中的语义信息异常进行精准修补与校正。</p>
        </div>
      </div>
    </div>

  </div>

  <script is:inline>
    function forceWakeUpZhButtons() {
      const hub = document.getElementById('global-floating-hub');
      if (hub) {
        if (hub.parentElement !== document.body) {
          document.body.appendChild(hub);
        }
        hub.classList.remove('hidden');
        hub.style.display = 'block';
        
        const waBtn = document.getElementById('global-whatsapp-btn');
        if (waBtn) {
          waBtn.style.setProperty('display', 'flex', 'important');
          waBtn.style.setProperty('z-index', '2147483647', 'important');
          waBtn.style.setProperty('opacity', '1', 'important');
          waBtn.style.setProperty('visibility', 'visible', 'important');
        }
      }
    }
    forceWakeUpZhButtons();
    document.addEventListener('astro:after-swap', forceWakeUpZhButtons);
    document.addEventListener('DOMContentLoaded', forceWakeUpZhButtons);
  </script>
</Layout>