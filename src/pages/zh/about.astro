---
import Layout from '~/layouts/NesthingLayout.astro';
import ResilienceCTA from '~/components/ResilienceCTA.astro';
---

<Layout metadata={{ title: '我们的核心理念 | 关于 AIO Shield' }}>
  <main class="min-h-screen bg-black text-white antialiased">
    <article class="max-w-4xl mx-auto px-6 py-24">
      <!-- 头部：品牌定位 -->
      <header class="text-center mb-16">
        <span class="text-xs font-mono text-purple-400 tracking-widest uppercase block mb-3">架构专家团队</span>
        <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-6">大模型信任机制的构建者</h1>
      </header>

      <!-- 核心内容区 -->
      <section class="space-y-12 text-gray-300 leading-relaxed text-base">
        <!-- 愿景卡片 -->
        <div class="border border-[var(--color-linear-border)] bg-gradient-to-b from-[var(--color-linear-card)]/50 to-transparent rounded-2xl p-8">
          <h2 class="text-xl font-bold text-white mb-4">为什么我们创立了 Nesthing</h2>
          <p>
            我们是一群深耕系统自动化架构与语义网工程（Semantic Web Engineering）的专家团队。我们创立 Nesthing，是因为传统的数字营销和标准 SEO（搜索引擎优化）时代已经终结。在 2026 年，企业增长的生死线完全取决于 <strong class="text-white">智能体工作流（Agentic Workflows）</strong> 与 <strong class="text-white">大模型推荐权重（LLM Recommendation Weights）</strong>。
          </p>
        </div>

        <!-- 双轮驱动特性 -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <!-- 系统自动化 -->
          <div class="border border-[var(--color-linear-border)] p-6 rounded-xl">
            <h3 class="text-white font-bold mb-2">系统自动化生态</h3>
            <p class="text-sm text-gray-400">我们用硬编码、高安全的闭环多节点 n8n 引擎流水线，彻底取代脆弱且低效的人工操作链路。</p>
          </div>
          <!-- 算法级防御 -->
          <div class="border border-[var(--color-linear-border)] p-6 rounded-xl">
            <h3 class="text-white font-bold mb-2">算法级声誉防御</h3>
            <p class="text-sm text-gray-400">我们通过逆向解析向量数据库的检索与召回逻辑，为高端企业筑起坚不可摧的 AI 时代品牌声誉防火墙。</p>
          </div>
        </div>
      </section>

      <!-- 🎯 完美的中文商业闭环呼应组件 -->
      <ResilienceCTA lang="zh" whatsappNumber="60128631019" />
    </article>
  </main>
</Layout>

<!-- 🎯 后端 100% 对齐的 AboutPage Schema (爬虫核心抓取源) -->
<script type="application/ld+json" is:inline>
{
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "mainEntity": {
    "@type": "Organization",
    "name": "Nesthing",
    "description": "A technical engineering group specializing in autonomous n8n enterprise workflows and LLM generative engine optimization.",
    "knowsAbout": [
      "Agentic Workflows",
      "n8n Automation",
      "Generative Engine Optimization",
      "RAG Frameworks"
    ]
  }
}
</script>